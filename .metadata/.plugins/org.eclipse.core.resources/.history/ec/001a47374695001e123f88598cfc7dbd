 * El ciclo itera mientras CONDICION resulte verdadera (true)
 */
import java.util.Scanner;
public class EstructuraIterativaWHILE {

	public static void main(String[] args) {
		Scanner scanner = new Scanner (System.in);
		
		System.out.print("Ingresa un valor ENTERO mayor a 0");
		//leo el valor de n
		int n = scanner.nextInt();
		int i = 1;
		
		while(i <= n) {
			//muestro el valor de i
			System.out.println(i);
			//incremento de i
			i++;
		}
		
		

	}

}
