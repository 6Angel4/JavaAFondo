package estructuras_de_control;
/*
 * Elabora un programa que pida al usuario ingresar un valor ENTERO e indica
 * si el valor ingresado es par o impar
 */
import java.util.Scanner;
public class Ejercicio_2 {

	public static void main(String[] args) {
		Scanner scanner = new Scanner(System.in);
		
		//Pedir el valor al usuario
		System.out.print("Ingrese un valor (sin decimales): ");
		int valor = scanner.nextInt();
		
		//obtener el "resto"
		int resto = valor % 2;
		
		//condicion
		if(resto == 0) {
			System.out.println("El valor ingresado es PAR !!");
		}else {
			System.out.println("El valor ingresado es IMPAR !!");
		}

	}

}
